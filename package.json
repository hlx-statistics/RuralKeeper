{
  "name": "retail-log",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:capacitor": "vue-tsc -b && vite build --mode capacitor",
    "preview": "vite preview",
    "typecheck": "vue-tsc -b --noEmit",
    "test:form": "node scripts/test-goods-form-logic.mjs",
    "cap:sync": "npm run build:capacitor && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:run:android": "npm run cap:sync && npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "idb": "^8.0.3",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@vitejs/plugin-vue": "^5.2.3",
    "typescript": "~5.8.3",
    "vite": "^6.2.4",
    "vite-plugin-pwa": "^0.21.2",
    "vue-tsc": "^2.2.8"
  }
}
